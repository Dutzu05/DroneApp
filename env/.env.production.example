DRONE_ALLOWED_ORIGINS=https://app.example.com
DRONE_ADMIN_EMAILS=admin@example.com
DRONE_ENV=production
DRONE_SESSION_SECRET=replace-with-a-long-random-secret
DRONE_COOKIE_SECURE=1
